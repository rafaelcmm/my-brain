{
    admin off
    auto_https off
}

# Require bearer token rendered by install/rotation scripts.
(bearer_auth) {
    @unauth not header Authorization "Bearer my-brain-local-token"
    header @unauth WWW-Authenticate `Bearer realm="my-brain"`
    respond @unauth "Unauthorized" 401
}

:3333 {
    import bearer_auth
    reverse_proxy my-brain-mcp:3333 {
        header_up Host {host}
        header_up -Authorization
        flush_interval -1
    }
}

:8080 {
    import bearer_auth
    reverse_proxy my-brain-orchestrator:8080 {
        header_up Host {host}
        header_up -Authorization
    }
}
