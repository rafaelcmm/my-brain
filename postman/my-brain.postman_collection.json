              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 4,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"hooks_remember\",\n    \"arguments\": {\n      \"content\": \"my-brain Postman test entry\",\n      \"type\": \"general\"\n    }\n  }\n}",
              "options": {
