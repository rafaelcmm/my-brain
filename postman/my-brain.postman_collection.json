{
  "info": {
    "_postman_id": "a0e1f2b3-0000-4000-8000-200000000001",
    "name": "my-brain",
    "description": "Local testing collection for the my-brain self-hosted memory stack.\n\nAll requests route through the Caddy gateway (`rest_base_url` on port 8080, `mcp_base_url` on port 3333) and require a Bearer token set in the `auth_token` environment variable.\n\nImport alongside `my-brain.postman_environment.json` and select the **my-brain (local)** environment before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Orchestrator",
      "description": "REST endpoints exposed by the Node orchestrator service (proxied through Caddy on port 8080).",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rest_base_url}}/health",
              "host": ["{{rest_base_url}}"],
              "path": ["health"]
            },
            "description": "Liveness probe. Returns service name, fixed `full` runtime mode, SONA enabled flag, and UTC timestamp.\n\nExpected: 200 OK with `status: \"ok\"`."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{rest_base_url}}/health",
                  "host": ["{{rest_base_url}}"],
                  "path": ["health"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"my-brain-orchestrator\",\n  \"mode\": \"full\",\n  \"sonaEnabled\": true,\n  \"timestamp\": \"2026-04-20T00:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rest_base_url}}/v1/status",
              "host": ["{{rest_base_url}}"],
              "path": ["v1", "status"]
            },
            "description": "Returns runtime configuration summary: fixed `full` mode, LLM model/endpoint, and whether the DB URL is configured.\n\nExpected: 200 OK. The `llm.endpoint` field should always point at the local Ollama sidecar."
          },
          "response": [
            {
              "name": "200 OK – full runtime",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{rest_base_url}}/v1/status",
                  "host": ["{{rest_base_url}}"],
                  "path": ["v1", "status"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"service\": \"my-brain-orchestrator\",\n  \"mode\": \"full\",\n  \"llm\": {\n    \"model\": \"qwen3.5:0.8b\",\n    \"endpoint\": \"http://my-brain-llm:11434\"\n  },\n  \"memory\": {\n    \"dbConfigured\": true\n  }\n}"
            }
          ]
        },
        {
          "name": "Unauthorized (token sanity check)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rest_base_url}}/health",
              "host": ["{{rest_base_url}}"],
              "path": ["health"]
            },
            "description": "Sends the health request **without** the Authorization header to verify the gateway rejects unauthenticated traffic.\n\nExpected: 401 Unauthorized with `WWW-Authenticate: Bearer realm=\"my-brain\"`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "MCP Bridge",
      "description": "MCP (Model Context Protocol) endpoints exposed by mcp-proxy (proxied through Caddy on port 3333).\n\nThis project supports Streamable HTTP only:\n1. `POST /mcp` with `initialize`.\n2. Copy the `Mcp-Session-Id` response header into the `mcp_session_id` environment variable.\n3. Reuse that value in the `Mcp-Session-Id` request header for later calls.\n\nLegacy `/sse` and `/messages` routes are intentionally blocked at the gateway.",
      "item": [
        {
          "name": "Initialize session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"2024-11-05\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"1.0.0\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            },
            "description": "Initializes an MCP session over Streamable HTTP. Copy the `Mcp-Session-Id` response header into the `mcp_session_id` environment variable before using the follow-up requests.\n\n**curl equivalent:**\n```bash\ncurl -i -X POST -H 'Authorization: Bearer {{auth_token}}' \\\n     -H 'Content-Type: application/json' \\\n     -H 'Accept: application/json, text/event-stream' \\\n     -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{},\"clientInfo\":{\"name\":\"postman\",\"version\":\"1.0.0\"}}}' \\\n     http://127.0.0.1:3333/mcp\n```"
          },
          "response": []
        },
        {
          "name": "List tools",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcp_session_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            },
            "description": "Returns the full list of tools registered by the ruvector MCP server. Requires `mcp_session_id` from the initialize response header."
          },
          "response": []
        },
        {
          "name": "List resources",
          "request": {
