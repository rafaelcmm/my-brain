{
  "info": {
    "_postman_id": "a0e1f2b3-0000-4000-8000-200000000001",
    "name": "my-brain (minimal)",
    "description": "Minimal general smoke tests for local my-brain stack.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "General Smoke",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rest_base_url}}/health",
              "host": ["{{rest_base_url}}"],
              "path": ["health"]
            },
            "description": "Checks orchestrator liveness through gateway."
          },
          "response": []
        },
        {
          "name": "Initialize MCP session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"2024-11-05\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"1.0.0\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            },
            "description": "Creates MCP session and stores Mcp-Session-Id in environment."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const sessionId = pm.response.headers.get('Mcp-Session-Id') || pm.response.headers.get('mcp-session-id');",
                  "pm.test('initialize returns Mcp-Session-Id header', function () {",
                  "  pm.expect(sessionId, 'Mcp-Session-Id response header').to.be.a('string').and.not.empty;",
                  "});",
                  "if (sessionId) {",
                  "  pm.environment.set('mcp_session_id', sessionId.trim());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List MCP tools",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcp_session_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            },
            "description": "Verifies MCP bridge works with active session."
          },
          "response": []
        },
        {
          "name": "LLM generate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{rest_base_url}}/llm/api/generate",
              "host": ["{{rest_base_url}}"],
              "path": ["llm", "api", "generate"]
            },
            "description": "Runs minimal model generation through gateway llm proxy."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const model = pm.environment.get('llm_model') || 'qwen3.5:0.8b';",
                  "const prompt = pm.environment.get('llm_prompt') || 'Reply with one word: ready';",
                  "const payload = {",
                  "  model,",
                  "  prompt,",
                  "  stream: false,",
                  "  think: false,",
                  "  options: { temperature: 0, num_predict: 24 }",
                  "};",
                  "pm.request.body.update(JSON.stringify(payload, null, 2));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('generate returns response text', function () {",
                  "  pm.expect(body.response, 'Ollama response').to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": []
}
