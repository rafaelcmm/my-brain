              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcp_session_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 3,\n  \"method\": \"resources/list\",\n  \"params\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            },
            "description": "Returns the list of resources exposed by the ruvector MCP server."
          },
          "response": []
        },
        {
          "name": "Call tool – remember context",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcp_session_id}}"
              }
            ],
            "body": {
