{
  "info": {
    "_postman_id": "a0e1f2b3-0000-4000-8000-200000000001",
    "name": "my-brain (v2 envelope)",
    "description": "Smoke and contract checks for my-brain v2 envelope APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Service Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{rest_base_url}}/health",
              "host": ["{{rest_base_url}}"],
              "path": ["health"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Capabilities envelope",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{rest_base_url}}/v1/capabilities",
              "host": ["{{rest_base_url}}"],
              "path": ["v1", "capabilities"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('capabilities returns envelope', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body).to.have.property('summary');",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body).to.have.property('synthesis');",
                  "  pm.expect(body.synthesis).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Memory v2",
      "item": [
        {
          "name": "Remember memory",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Postman envelope smoke memory\",\n  \"type\": \"note\",\n  \"scope\": \"repo\",\n  \"metadata\": {\n    \"repo\": \"my-brain\",\n    \"language\": \"typescript\",\n    \"source\": \"postman\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{rest_base_url}}/v1/memory",
              "host": ["{{rest_base_url}}"],
              "path": ["v1", "memory"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('remember returns envelope with id', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data).to.have.property('id');",
                  "  pm.expect(body.synthesis).to.have.property('status');",
                  "});",
                  "if (body.data && body.data.id) {",
                  "  pm.environment.set('memory_id', String(body.data.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Recall memory",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"envelope smoke memory\",\n  \"top_k\": 5,\n  \"scope\": \"repo\",\n  \"repo\": \"my-brain\",\n  \"language\": \"typescript\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{rest_base_url}}/v1/memory/recall",
              "host": ["{{rest_base_url}}"],
              "path": ["v1", "memory", "recall"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('recall returns envelope and no mode/model contract', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body).to.have.property('summary');",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body).to.have.property('synthesis');",
                  "  pm.expect(body.synthesis).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject legacy recall mode",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"legacy mode should fail\",\n  \"mode\": \"raw\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{rest_base_url}}/v1/memory/recall",
              "host": ["{{rest_base_url}}"],
              "path": ["v1", "memory", "recall"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('legacy mode is rejected with invalid input', function () {",
                  "  pm.response.to.have.status(400);",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.error).to.eql('INVALID_INPUT');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Forget memory",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{memory_id}}\",\n  \"mode\": \"soft\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{rest_base_url}}/v1/memory/forget",
              "host": ["{{rest_base_url}}"],
              "path": ["v1", "memory", "forget"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('forget returns envelope', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body).to.have.property('summary');",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.synthesis).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "MCP Bridge",
      "item": [
        {
          "name": "Initialize MCP session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"2024-11-05\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"2.0.0\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const sessionId = pm.response.headers.get('Mcp-Session-Id') || pm.response.headers.get('mcp-session-id');",
                  "pm.test('initialize returns Mcp-Session-Id header', function () {",
                  "  pm.expect(sessionId).to.be.a('string').and.not.empty;",
                  "});",
                  "if (sessionId) {",
                  "  pm.environment.set('mcp_session_id', sessionId.trim());",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List MCP tools",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcp_session_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{mcp_base_url}}/mcp",
              "host": ["{{mcp_base_url}}"],
              "path": ["mcp"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('tools/list returns tool array', function () {",
                  "  pm.expect(body).to.have.property('result');",
                  "  pm.expect(body.result).to.have.property('tools');",
                  "  pm.expect(body.result.tools).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": []
}
