                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 5,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"recall_memory\",\n    \"arguments\": {\n      \"query\": \"Postman test\",\n      \"topK\": 5\n    }\n  }\n}",
              "options": {
