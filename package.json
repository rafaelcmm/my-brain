{
  "name": "my-brain",
  "version": "0.0.1",
  "description": "A self learning system to improve LLMs with feedback",
  "type": "commonjs",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose down && docker compose up -d --build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ruvector/core": "^0.1.31",
    "@ruvector/sona": "^0.1.5",
    "@types/cors": "^2.8.19",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
