{
  "name": "my-brain",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted memory and orchestration layer for MCP clients.",
  "license": "MIT",
  "scripts": {
    "docker:up": "docker compose up -d --build",
    "docker:up:cpu": "docker compose -f docker-compose.yml up -d --build",
    "docker:init:cpu": "npm run docker:up:cpu",
    "docker:down": "docker compose down",
    "docker:down:cpu": "docker compose -f docker-compose.yml down",
    "docker:restart": "docker compose restart",
    "docker:logs": "docker compose logs -f",
    "lint": "npm run lint --prefix src/orchestrator",
    "test": "npm run test --prefix src/orchestrator",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
