# my-brain environment configuration
# SECURITY WARNING: do not keep default credentials in shared environments.
# Copy this file to .env and replace placeholders marked <CHANGE_ME>.

# ─────────────────────────────────────────────────────────────────────
# Project identity
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_PROJECT_NAME=my-brain
MYBRAIN_NETWORK_NAME=my-brain-net

# ─────────────────────────────────────────────────────────────────────
# Host bindings (gateway publishes only these ports)
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_BIND_HOST=127.0.0.1
MYBRAIN_MCP_PORT=3333
MYBRAIN_REST_PORT=8080
MYBRAIN_WEB_PORT=3000

# ─────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_DB_IMAGE=ruvnet/ruvector-postgres:latest
MYBRAIN_DB_USER=mybrain
MYBRAIN_DB_PASSWORD=<CHANGE_ME>
MYBRAIN_DB_NAME=mybrain_db
MYBRAIN_DB_VOLUME=my-brain-db-data

# ─────────────────────────────────────────────────────────────────────
# Orchestrator runtime
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_ORCHESTRATOR_IMAGE_TAG=my-brain/orchestrator:local
MYBRAIN_ORCHESTRATOR_VOLUME_MODELS=my-brain-models
MYBRAIN_ORCHESTRATOR_VOLUME_STATE=my-brain-state
MYBRAIN_SONA_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Memory tuning (HNSW index + embedding dimensionality)
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_EMBEDDING_DIM=1024

# ─────────────────────────────────────────────────────────────────────
# CORS and MCP origin validation
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_CORS_ORIGINS=http://localhost,http://127.0.0.1
MYBRAIN_ALLOWED_MCP_ORIGINS=http://localhost,http://127.0.0.1

# ─────────────────────────────────────────────────────────────────────
# Authentication and rate limiting
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_AUTH_TOKEN_FILE=/run/secrets/auth-token
MYBRAIN_FORCE_REGEN_TOKEN=false
MYBRAIN_MIN_TOKEN_LENGTH=73
MYBRAIN_INTERNAL_API_KEY=<CHANGE_ME>
# Set true only when Caddy is the sole bearer-token enforcement point and the
# orchestrator container cannot read the token secret file (EACCES). Defaults
# to false (fail-closed).
MYBRAIN_ALLOW_GATEWAY_ONLY_AUTH=false
MYBRAIN_RATE_LIMIT_PER_MIN=60
MYBRAIN_MAX_REQUEST_BODY_BYTES=1048576

# ─────────────────────────────────────────────────────────────────────
# Web app (Next.js operator UI)
# ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
MYBRAIN_WEB_SESSION_SECRET=<CHANGE_ME>
MYBRAIN_WEB_PUBLIC_BASE_URL=http://localhost:3000
MYBRAIN_WEB_RATE_LIMIT_LOGIN=5
MYBRAIN_WEB_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────
# Local LLM runtime (Ollama)
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_LLM_IMAGE=ollama/ollama:latest
MYBRAIN_LLM_VOLUME=my-brain-ollama
MYBRAIN_LLM_MODEL=qwen3.5:0.8b
MYBRAIN_RECALL_PROCESS_TIMEOUT_MS=180000
MYBRAIN_SYNTH_TIMEOUT_MS=15000
MYBRAIN_EMBEDDING_MODEL=qwen3-embedding:0.6b
# Leave empty for CPU-only; set count (e.g. 1) to reserve NVIDIA GPUs via override.
MYBRAIN_LLM_GPU_COUNT=

# ─────────────────────────────────────────────────────────────────────
# Logs and telemetry
# ─────────────────────────────────────────────────────────────────────
MYBRAIN_LOG_LEVEL=info
MYBRAIN_PROMETHEUS_PORT=9090
