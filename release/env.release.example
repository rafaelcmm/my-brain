MCP_IMAGE=ghcr.io/ORG/my-brain:v1.0.0
MCP_SERVER_NAME=my-brain
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3737

# Optional bootstrap token for first startup only. Use 32+ chars.
MCP_AUTH_TOKEN=
MCP_AUTH_STORE_PATH=/data/mcp-auth-tokens.json
MCP_ALLOWED_ORIGINS=
MCP_MAX_BODY_BYTES=1048576
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120

EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_QUANTIZED=false
MODEL_CACHE_DIR=/models

SONA_MICRO_LORA_RANK=2
SONA_BASE_LORA_RANK=16
SONA_MICRO_LORA_LR=0.002
SONA_QUALITY_THRESHOLD=0.3
SONA_PATTERN_CLUSTERS=100
SONA_EWC_LAMBDA=2000

RUVECTOR_DB_PATH=/data/ruvector.db
