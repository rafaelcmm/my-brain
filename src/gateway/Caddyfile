{
	admin off
	auto_https off
	servers {
		timeouts {
			read_body 30s
			read_header 10s
			write 60s
			idle 120s
		}
		max_header_size 16KB
	}
}

# Require bearer token from the mounted secret file.
(bearer_auth) {
	@unauth not header Authorization "Bearer {file./run/secrets/auth-token}"
	header @unauth WWW-Authenticate `Bearer realm="my-brain"`
	respond @unauth "Unauthorized" 401
}

# Security headers applied to all responses.
(security_headers) {
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
		defer
	}
}

# Rate limiting: 60 requests per minute per IP.
(rate_limit) {
	rate_limit {
		zone my_brain_zone {
			key {remote_host}
			events 60
			window 1m
		}
	}
}

:3333 {
	import bearer_auth
	import security_headers
	import rate_limit
	# Block legacy SSE entrypoints at the gateway so operators only see the
	# supported Streamable HTTP contract exposed by /mcp.
	@legacy_sse path /sse /messages /messages/*
	handle @legacy_sse {
		header Link "</mcp>; rel=\"successor\""
		respond "Legacy MCP SSE transport removed. Use POST /mcp with type \"http\"." 410
	}

	@streamable_http path /mcp /mcp/*
	handle @streamable_http {
		reverse_proxy my-brain-mcp:3333 {
			header_up Host {host}
			header_up -Authorization
			header_up X-Mybrain-Internal-Key {$MYBRAIN_INTERNAL_API_KEY}
			flush_interval -1
		}
	}

	handle {
		respond "Not Found" 404
	}
}

:8080 {
	import bearer_auth
	import security_headers
	import rate_limit
	handle_path /llm/* {
		reverse_proxy my-brain-llm:11434 {
			header_up Host {host}
			header_up -Authorization
		}
	}

	reverse_proxy my-brain-orchestrator:8080 {
		header_up Host {host}
		header_up -Authorization
		header_up X-Mybrain-Internal-Key {$MYBRAIN_INTERNAL_API_KEY}
	}
}

:3000 {
	import security_headers
	@login path /api/auth/login
	rate_limit @login {
		zone my_brain_web_login_zone {
			key {remote_host}
			events 10
			window 1m
		}
	}
	reverse_proxy my-brain-web:3000 {
		header_up Host {host}
	}
}
